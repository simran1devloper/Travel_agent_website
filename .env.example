# Copy to .env and fill in real values for production

VITE_API_BASE_URL=https://api.yourdomain.com
VITE_ADMIN_TOKEN=          # REQUIRED in production — set a strong random token
VITE_CUSTOMER_TOKEN=       # REQUIRED in production — set a strong random token

# Auth0 (optional but recommended for production)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=

# Backend (set in your server environment, not committed)
JOURNEYMAKERS_ADMIN_TOKEN=   # Must match VITE_ADMIN_TOKEN
JOURNEYMAKERS_JWT_SECRET=    # Strong random string, min 32 chars
